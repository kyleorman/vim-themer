#include <iostream>
#include <vector>
#include <string>

class Example {
public:
    Example(const std::string& name, int value) : name(name), value(value) {}

    void display() const {
        std::cout << name << ": " << value << std::endl;
    }

private:
    std::string name;
    int value;
};

int main() {
    Example example("C++ Example", 42);
    example.display();

    for (int i = 0; i < 5; ++i) {
        std::cout << "Count: " << i << std::endl;
    }
    return 0;
}
